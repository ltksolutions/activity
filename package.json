{
  "name": "activity",
  "version": "0.1.0",
  "description": "Platforma pre evidenciu aktivít, mentoring a komunikáciu v slovenskom športe",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:docs": "npm run dev --workspace=@activity/docs",
    "build:docs": "npm run build --workspace=@activity/docs",
    "dev:web": "cd apps/web && npx serve . -p 8080",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "license": "EUPL-1.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/ltksolutions/activity.git"
  }
}
